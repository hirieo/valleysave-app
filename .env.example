# Google OAuth — Desktop (macOS, Windows, Linux)
# Obtén tus credenciales en https://console.cloud.google.com
# Tipo de cliente: "Aplicación de escritorio"
# En Android/iOS no se usa este archivo — las credenciales van en
# google-services.json (Android) y GoogleService-Info.plist (iOS)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
